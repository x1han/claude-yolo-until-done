{
  "workflow_name": "claude-yolo-until-done",
  "default_run_root": "artifacts/yolo",
  "stages": [
    {
      "id": "stage-01",
      "hook_stage": 1,
      "next_action": "validate runtime and bundle",
      "complete_checkoffs": ["runtime-ready", "runtime-context-recorded", "bundle-ready"]
    },
    {
      "id": "stage-02",
      "hook_stage": 2,
      "next_action": "load run state and claim exactly one next action",
      "complete_checkoffs": []
    },
    {
      "id": "stage-03",
      "hook_stage": 3,
      "next_action": "execute current fix loop and rerun required verification",
      "complete_checkoffs": ["current-gate-verified", "report-updated"]
    },
    {
      "id": "stage-04",
      "hook_stage": 4,
      "next_action": "classify blockers and continue unless human-blocked is justified",
      "complete_checkoffs": []
    },
    {
      "id": "stage-05",
      "hook_stage": 5,
      "next_action": "run final acceptance and certify completion",
      "complete_checkoffs": ["completion-certified"]
    }
  ]
}
