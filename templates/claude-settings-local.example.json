{
  "hooks": {
    "SessionStart": [
      {
        "metadata": {
          "workflow": "claude-yolo-until-done",
          "hook_role": "SessionStart",
          "run_root": "artifacts/yolo"
        },
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<skill-root>/workflow/claude_hook_bridge.py\" --event session-start --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \"artifacts/yolo\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "metadata": {
          "workflow": "claude-yolo-until-done",
          "hook_role": "Stop",
          "run_root": "artifacts/yolo"
        },
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<skill-root>/workflow/claude_hook_bridge.py\" --event stop --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \"artifacts/yolo\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "metadata": {
          "workflow": "claude-yolo-until-done",
          "hook_role": "SessionEnd",
          "run_root": "artifacts/yolo"
        },
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<skill-root>/workflow/claude_hook_bridge.py\" --event session-end --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \"artifacts/yolo\" --settings-file \".claude/settings.local.json\""
          }
        ]
      }
    ]
  }
}
