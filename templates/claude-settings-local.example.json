{
  "hooks": {
    "SessionStart": [
      {
        "metadata": {
          "workflow": "claude-yolo-until-done",
          "hook_role": "SessionStart",
          "run_root": ".yolo",
          "hook_namespace": "claude-yolo"
        },
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<skill-root>/workflow/claude_hook_bridge.py\" --event session-start --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \".yolo\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "metadata": {
          "workflow": "claude-yolo-until-done",
          "hook_role": "Stop",
          "run_root": ".yolo",
          "hook_namespace": "claude-yolo"
        },
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<skill-root>/workflow/claude_hook_bridge.py\" --event stop --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \".yolo\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "metadata": {
          "workflow": "claude-yolo-until-done",
          "hook_role": "UserPromptSubmit",
          "run_root": ".yolo",
          "hook_namespace": "claude-yolo"
        },
        "hooks": [
          {
            "type": "command",
            "command": "\"<python>\" \"<skill-root>/workflow/claude_hook_bridge.py\" --event user-prompt-submit --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \".yolo\""
          }
        ]
      }
    ]
  }
}
