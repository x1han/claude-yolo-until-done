{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/path/to/python.exe\" \"C:/path/to/claude-yolo-until-done/workflow/claude_hook_bridge.py\" --event session-start --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \"artifacts/yolo\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/path/to/python.exe\" \"C:/path/to/claude-yolo-until-done/workflow/claude_hook_bridge.py\" --event stop --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \"artifacts/yolo\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/path/to/python.exe\" \"C:/path/to/claude-yolo-until-done/workflow/claude_hook_bridge.py\" --event session-end --project-dir \"$CLAUDE_PROJECT_DIR\" --run-root \"artifacts/yolo\" --settings-file \".claude/settings.local.json\""
          }
        ]
      }
    ]
  }
}
